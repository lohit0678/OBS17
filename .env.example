# ====================================================
# MONGODB
# ====================================================
# Your MongoDB connection string (Atlas or local)
# Example Atlas:  mongodb+srv://user:pass@cluster0.mongodb.net/erp_db
# Example Local:  mongodb://localhost:27017/erp_db
MONGODB_URI="mongodb+srv://YOUR_USER:YOUR_PASS@cluster0.mongodb.net/erp_db"

# ====================================================
# JWT
# ====================================================
# A long random secret string for signing JWT tokens
JWT_SECRET="your_super_secret_jwt_key_change_this_in_production"
# Token expiry duration (e.g. 7d, 24h, 1h)
JWT_EXPIRES_IN="7d"

# ====================================================
# GEMINI AI
# ====================================================
# Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# ====================================================
# APP
# ====================================================
# The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# Server port (default 3000)
PORT=3000
